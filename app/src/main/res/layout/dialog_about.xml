<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="@dimen/spacing_xxl"
    android:paddingTop="@dimen/spacing_xl"
    android:paddingBottom="@dimen/spacing_lg">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="480dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <!-- App Icon & Name -->
            <ImageView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@mipmap/ic_launcher"
                android:contentDescription="@string/app_name" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:text="@string/about_app_name"
                android:textColor="@color/on_surface"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:alpha="0.6"
                android:text="@string/about_slogan"
                android:textColor="@color/on_surface"
                android:textSize="13sp" />

            <!-- Description -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                android:lineSpacingExtra="4dp"
                android:text="@string/about_desc"
                android:textColor="@color/on_surface"
                android:textIsSelectable="true"
                android:textSize="14sp" />

            <!-- Features -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                android:text="@string/about_features_title"
                android:textColor="@color/on_surface"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:lineSpacingExtra="4dp"
                android:text="@string/about_features"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <!-- Tips -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                android:lineSpacingExtra="4dp"
                android:text="@string/about_tips"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginVertical="@dimen/spacing_lg"
                android:alpha="0.15"
                android:background="@color/on_surface" />

            <!-- Contact -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/about_contact"
                android:textColor="@color/text_secondary"
                android:textIsSelectable="true"
                android:textSize="12sp" />

            <!-- GitHub -->
            <TextView
                android:id="@+id/tvGithub"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:text="@string/about_github"
                android:textColor="@color/primary"
                android:textIsSelectable="true"
                android:textSize="12sp" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginVertical="@dimen/spacing_lg"
                android:alpha="0.15"
                android:background="@color/on_surface" />

            <!-- Donate -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/about_donate"
                android:textColor="@color/on_surface"
                android:textSize="14sp" />

            <ImageView
                android:id="@+id/ivQrDonate"
                android:layout_width="180dp"
                android:layout_height="180dp"
                android:layout_marginTop="@dimen/spacing_md"
                android:contentDescription="@string/about_donate"
                android:src="@drawable/img_qr_donate" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Close button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnClose"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/spacing_sm"
        android:text="@string/about_close"
        android:textColor="@color/text_secondary" />

</LinearLayout>
